generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}

model Task {
  id        Int      @id @default(autoincrement())
  name      String
  completed Boolean  @default(false)
}

model TemperatureLog {
  id        Int      @id @default(autoincrement())
  fridge    String
  value     Float
  createdAt DateTime @default(now())
}